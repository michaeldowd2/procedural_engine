{
  "name": "song_composer",
  "description": "Schema for procedural music composition",
  "properties": [
    {
      "name": "tempo",
      "type": "numeric",
      "range": [
        60,
        200
      ],
      "description": "Beats per minute"
    },
    {
      "name": "key",
      "type": "categorical",
      "values": [
        "C",
        "C#",
        "D",
        "D#",
        "E",
        "F",
        "F#",
        "G",
        "G#",
        "A",
        "A#",
        "B"
      ],
      "description": "Musical key"
    },
    {
      "name": "mode",
      "type": "categorical",
      "values": [
        "major",
        "minor",
        "dorian",
        "mixolydian",
        "phrygian"
      ],
      "description": "Musical mode/scale type"
    },
    {
      "name": "genre",
      "type": "tag_list",
      "min_items": 1,
      "max_items": 1,
      "description": "Genre tags",
      "note": "Each tag is treated as an independent item in association rules"
    },
    {
      "name": "tags",
      "type": "tag_list",
      "min_items": 1,
      "max_items": 3,
      "description": "Mood and emotion tags",
      "note": "Each tag is treated as an independent item in association rules"
    },
    {
      "name": "target_duration",
      "type": "numeric",
      "range": [
        60,
        600
      ],
      "description": "Target song duration in seconds"
    },
    {
      "name": "instruments",
      "type": "tag_list",
      "min_items": 1,
      "max_items": 8,
      "description": "List of instruments to use in the composition"
    },
    {
      "name": "structure",
      "type": "categorical",
      "values": [
        "verse-chorus-verse-chorus-bridge-chorus",
        "verse-verse-chorus-verse-chorus",
        "intro-verse-chorus-verse-chorus-outro",
        "verse-chorus-verse-chorus-verse-chorus",
        "intro-verse-bridge-chorus-outro"
      ],
      "description": "High-level song structure"
    },
    {
      "name": "parts",
      "type": "part_list",
      "description": "Individual song parts (verse, chorus, etc.) with properties",
      "part_schema": {
        "properties": [
          {
            "name": "part_type",
            "type": "categorical",
            "values": [
              "intro",
              "verse",
              "chorus",
              "bridge",
              "outro"
            ],
            "context": [
              "global.tags",
              "global.structure"
            ]
          },
          {
            "name": "part_tags",
            "type": "tag_list",
            "min_items": 0,
            "max_items": 3,
            "context": [
              "global.tags",
              "part_type"
            ],
            "description": "Mood/energy tags specific to this part"
          },
          {
            "name": "chords",
            "type": "item_list",
            "min_items": 2,
            "max_items": 8,
            "item_library": "chord_progressions",
            "context": [
              "global.key",
              "global.mode",
              "part_type",
              "part_tags"
            ],
            "description": "Chord progression for this part"
          }
        ]
      }
    }
  ],
  "notes": [
    "Properties are generated in the order listed",
    "Context references allow later properties to depend on earlier ones",
    "global.* refers to top-level properties",
    "Item libraries (instruments, patterns, chords) can contain 100s-1000s of items",
    "Embeddings are used for items not seen in training datasets"
  ]
}
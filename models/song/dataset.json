{
  "name": "composer_dataset",
  "description": "Association rules and embeddings for music composition",
  "data_sources": [
    {
      "name": "spotify_songs",
      "file": "data/spotify/spotify_songs.csv",
      "type": "csv",
      "delimiter": ",",
      "min_support": 0.01,
      "min_confidence": 0.1,
      "max_antecedent_size": 5,
      "samples": 20000,
      "min_item_freq": 0.001,
      "mappings": [
        { "column": "playlist_genre", "target": "genre"},
        { "column": "key", "target": "key" },
        { "column": "mode", "target": "mode" },
        { "column": "tempo", "target": "tempo" },
        { "column": "duration_ms", "target": "target_duration" }
      ],
      "preprocessing": {
        "tempo": {
          "type": "bins",
          "bins": [0, 90, 120, 150, 300],
          "labels": ["tempo_slow", "tempo_moderate", "tempo_fast", "tempo_very_fast"],
          "target": "tags"
        },
        "energy": {
          "type": "bins",
          "bins": [0, 0.33, 0.66, 1.0],
          "labels": ["low_energy", "medium_energy", "high_energy"],
          "target": "tags"
        },
        "valence": {
          "type": "bins",
          "bins": [0, 0.33, 0.66, 1.0],
          "labels": ["dark_mood", "neutral_mood", "happy_mood"],
          "target": "tags"
        },
        "target_duration": {
          "type": "bins",
          "bins": [0, 120, 180, 240, 300, 600],
          "labels": ["short", "medium-short", "medium", "medium-long", "long"],
          "target": "tags",
          "inject_on_sample": false
        }
      }
    },
    {
      "name": "jamendo_tags",
      "file": "data/jamendo/raw_30s_cleantags_50artists.tsv",
      "type": "wide_tsv",
      "delimiter": "\t",
      "group_by": "TRACK_ID",
      "min_support": 0.005,
      "min_confidence": 0.1,
      "max_antecedent_size": 5,
      "samples": 20000,
      "min_item_freq": 0.001,
      "extract": {
        "prefixes": {
          "genre---": "genre",
          "mood/theme---": "tags",
          "instrument---": "instruments"
        }
      }
    },
    {
      "name": "seg_label_hard",
      "folder": "data/SegLabelHard",
      "type": "time_series_dir",
      "aggregate": "max",
      "min_support": 0.1,
      "min_confidence": 0.4,
      "max_antecedent_size": 3,
      "samples_per_source": 500,
      "min_item_freq": 0.005,
      "extract": {
        "prefixes": {
          "Emotion-": "tags",
          "Instrument_-_": "instruments",
          "Vocals-": "vocals"
        },
        "exclude_suffixes": [
          "-Solo"
        ]
      }
    },
    {
      "name": "music_metadata",
      "file": "data/music_metadata.csv",
      "type": "csv",
      "delimiter": ",",
      "min_support": 0.1,
      "min_confidence": 0.5,
      "max_antecedent_size": 3,
      "min_item_freq": 0,
      "mappings": [
        { "column": "genre",      "target": "genre" },
        { "column": "key",        "target": "key" },
        { "column": "mode",       "target": "mode" },
        { "column": "tempo",      "target": "tempo" },
        { "column": "mood",       "target": "tags" },
        { "column": "complexity", "target": "tags" }
      ],
      "preprocessing": {
        "tempo": {
          "type": "bins",
          "bins": [0, 90, 120, 150, 300],
          "labels": ["tempo_slow", "tempo_moderate", "tempo_fast", "tempo_very_fast"],
          "target": "tags"
        },
        "complexity": {
          "type": "add_suffix",
          "suffix": "_complexity"
        }
      }
    },
    {
      "name": "song_structures",
      "file": "data/song_structures.csv",
      "type": "csv",
      "delimiter": ",",
      "mappings": [
        {
          "column": "genre",
          "target": "genre"
        },
        {
          "column": "mood",
          "target": "tags"
        },
        {
          "column": "structure",
          "target": "structure"
        }
      ]
    }
  ],
  "item_libraries": {
    "instrument_presets": {
      "file": "data/instrument_presets.json",
      "embedding_file": "data/instrument_embeddings.npy",
      "description": "Library of instrument presets with metadata tags"
    },
    "chord_progressions": {
      "file": "data/chord_progressions.json",
      "description": "Common chord progressions with key/mode associations"
    }
  },
  "manual_rules": {
    "file": "data/manual_rules.json"
  },
  "generation_params": {
    "tag_confidence_threshold": 0.2
  },
  "embedding_params": {
    "dimension": 100,
    "algorithm": "item2vec",
    "context_window": 5,
    "note": "Learn item embeddings for large libraries (instruments, MIDI patterns)"
  },
  "tag_synonyms": [
    [
      "tags=Happy",
      "tags=happy",
      "tags=happy_mood"
    ],
    [
      "tags=Sad",
      "tags=sad",
      "tags=melancholic",
      "tags=dark_mood"
    ],
    [
      "tags=dark",
      "tags=dark_mood"
    ],
    [
      "tags=Calming / Soothing",
      "tags=calm",
      "tags=relaxing",
      "tags=meditative",
      "tags=mellow"
    ],
    [
      "tags=Laid-back / Mellow",
      "tags=mellow",
      "tags=easylistening",
      "tags=chillout"
    ],
    [
      "tags=Arousing / Awakening",
      "tags=Exciting / Thrilling",
      "tags=energetic",
      "tags=high_energy"
    ],
    [
      "tags=Powerful / Strong",
      "tags=powerful",
      "tags=epic",
      "tags=high_energy"
    ],
    [
      "tags=Loving / Romantic",
      "tags=Touching / Loving",
      "tags=romantic",
      "tags=love"
    ],
    [
      "tags=Positive / Optimistic",
      "tags=positive",
      "tags=uplifting",
      "tags=upbeat",
      "tags=hopeful"
    ],
    [
      "tags=Carefree / Lighthearted",
      "tags=fun",
      "tags=Light / Playful"
    ],
    [
      "tags=Cheerful / Festive",
      "tags=happy",
      "tags=party",
      "tags=summer"
    ],
    [
      "tags=Emotional / Passionate",
      "tags=emotional",
      "tags=dramatic"
    ],
    [
      "tags=Tender / Soft",
      "tags=soft",
      "tags=slow"
    ],
    [
      "tags=fast",
      "tags=tempo_fast",
      "tags=tempo_very_fast"
    ],
    [
      "tags=slow",
      "tags=tempo_slow"
    ],
    [
      "tags=deep",
      "tags=low_energy"
    ]
  ]
}